  <!-- L4 混合：物理 jaw = 旧 prismatic（proven）挂新 jaw mesh；连杆件纯视觉跟随 -->
  <joint name="grasper_L_jaw_left_Joint" type="prismatic">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="grasper_base_L_Link" />
    <child link="grasper_L_jaw_left_Link" />
    <axis xyz="0 1 0" />
    <limit lower="-0.0045" upper="0.0375" effort="20.0" velocity="0.5" />
  </joint>
  <joint name="grasper_L_jaw_right_Joint" type="prismatic">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="grasper_base_L_Link" />
    <child link="grasper_L_jaw_right_Link" />
    <axis xyz="0 -1 0" />
    <limit lower="-0.0045" upper="0.0375" effort="20.0" velocity="0.5" />
  </joint>
  <joint name="grasper_R_jaw_left_Joint" type="prismatic">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="grasper_base_R_Link" />
    <child link="grasper_R_jaw_left_Link" />
    <axis xyz="0 1 0" />
    <limit lower="-0.0045" upper="0.0375" effort="20.0" velocity="0.5" />
  </joint>
  <joint name="grasper_R_jaw_right_Joint" type="prismatic">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="grasper_base_R_Link" />
    <child link="grasper_R_jaw_right_Link" />
    <axis xyz="0 -1 0" />
    <limit lower="-0.0045" upper="0.0375" effort="20.0" velocity="0.5" />
  </joint>

  <!-- Virtual TCP frames:
       wrist_roll_*_Link 的 +x 是 wrist 旋转轴 (向手腕前方),
       但 RoboTwin 硬编码假设 ee_link 的 +x = grasper approach direction.
       dach_tron2 实际 approach = wrist_roll 的 -z (gripper 沿 -z 悬挂).
       这里加 fixed link 通过 rpy=(0, π/2, 0) 把 +x 旋到 wrist_roll 的 -z,
       Curobo ee_link 改用 tcp_*_Link 即可绕过约定不一致, 不改 wrist_roll 物理. -->
  <link name="tcp_L_Link">
    <inertial>
      <mass value="0.0001" />
      <origin xyz="0 0 0" rpy="0 0 0" />
      <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9" />
    </inertial>
  </link>
  <joint name="tcp_L_Joint" type="fixed">
    <origin xyz="0 0 0" rpy="0 1.5707963267948966 0" />
    <parent link="wrist_roll_L_Link" />
    <child link="tcp_L_Link" />
  </joint>

  <link name="tcp_R_Link">
    <inertial>
      <mass value="0.0001" />
      <origin xyz="0 0 0" rpy="0 0 0" />
      <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9" />
    </inertial>
  </link>
